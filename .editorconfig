root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
ktlint_code_style = ktlint_official
max_line_length = 120
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
# Compose Composable functions are PascalCase by convention.
# The compose-rules custom rule set (io.nlopez.compose.rules) covers the
# Compose-specific naming check; disable the standard function-naming rule
# so it does not flag @Composable functions.
ktlint_standard_function-naming = disabled

[*.{xml,json,yml,yaml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
