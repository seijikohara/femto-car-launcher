{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./gradlew assembleDebug)",
      "Bash(./gradlew assembleRelease)",
      "Bash(./gradlew lint)",
      "Bash(./gradlew lintDebug)",
      "Bash(./gradlew test)",
      "Bash(./gradlew testDebugUnitTest)",
      "Bash(./gradlew tasks)",
      "Bash(./gradlew tasks --all)",
      "Bash(./gradlew dependencies *)",
      "Bash(./gradlew app:dependencies *)",
      "Bash(./gradlew clean)",
      "Bash(./gradlew --version)",
      "Bash(./gradlew help *)",
      "Bash(git status)",
      "Bash(git status --short)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git ls-files *)",
      "Bash(git config user.name)",
      "Bash(git config user.email)",
      "Bash(ls *)",
      "Bash(file *)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(stat *)",
      "Bash(curl -fsSL -I *)",
      "Bash(curl -fsSL --head *)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x *)",
      "Bash(./gradlew :app:lintDebug)",
      "Bash(./gradlew spotlessCheck)",
      "Bash(./gradlew spotlessApply)",
      "Bash(./gradlew :app:spotlessCheck)",
      "Bash(./gradlew :app:spotlessApply)",
      "Bash(./gradlew dependencyUpdates *)",
      "Bash(./gradlew versionCatalogUpdate *)",
      "Bash(mv *)",
      "WebFetch(domain:developer.android.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:lecoauto.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Read(./local.properties)",
      "Read(./.idea/**)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Read(**/google-services.json)"
    ]
  }
}
